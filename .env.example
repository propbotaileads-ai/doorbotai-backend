# PropBot AI — Environment Variables
# Render pe ye sab "Environment Variables" mein daalo

# BLAND.AI — Voice Calling
BLAND_API_KEY=your_bland_api_key_here

# GMAIL — Email Notifications  
GMAIL_USER=propbotai.leads@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# GOOGLE SHEETS — Lead Database
# Sheet URL se copy karo: /spreadsheets/d/COPY_THIS/edit
GOOGLE_SHEETS_ID=your_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=propbot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key\n-----END PRIVATE KEY-----"

# SERVER
PORT=3000
BASE_URL=https://your-app.onrender.com

# LEMON SQUEEZY — Payments
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
